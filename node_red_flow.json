    {
        "id": "2f30c2f8d39a91b3",
        "type": "function",
        "z": "dbabb75e0b0c4959",
        "name": "Zapakiraj sve za robot",
        "func": "// 1. Izvlačimo sve podatke iz zajedničke memorije\nlet sekvenca = flow.get('moja_sekvenca') || [];\nlet brzina = flow.get('brzina') || 500;       // Ako klizač nije diran, zadano je 500\nlet ubrzanje = flow.get('ubrzanje') || 50;    // Ako klizač nije diran, zadano je 50\n\n// Sigurnosna provjera: Ako nema snimljenih točaka, ne idemo dalje\nif (sekvenca.length === 0) {\n    node.error(\"Nema snimljenih točaka za izvođenje pokreta!\");\n    return null;\n}\n\n// 2. Slažemo sve u jedan zajednički objekt (spojeno ime varijable)\nlet paketPodataka = {\n    brzina: brzina,\n    ubrzanje: ubrzanje,\n    tocke: sekvenca\n};\n\n// 3. Pretvaramo taj paket u čist tekst (JSON format)\nmsg.payload = JSON.stringify(paketPodataka);\nreturn msg;",
