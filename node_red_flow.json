    {
        "id": "ed3392147492ce83",
        "type": "function",
        "z": "dbabb75e0b0c4959",
        "name": "Dodaj u sekvencu",
        "func": "// 1. Razbijamo sav dobiveni tekst na pojedinačne linije\nlet linije = msg.payload.trim().split('\\n');\n\n// 2. Uzimamo isključivo zadnju liniju (tamo gdje su naši čisti brojevi)\nlet zadnjaLinija = linije[linije.length - 1].trim();\n\n// 3. Pretvaramo tu zadnju liniju u listu brojeva\nlet novaTocka = zadnjaLinija.split(',').map(Number);\n\n// Sigurnosna provjera: ako linija ne sadrži točno 6 brojeva, ignoriraj je\nif (novaTocka.length === 6 && !novaTocka.includes(NaN)) {\n\n    // 4. Dohvati trenutnu listu iz zajedničke memorije\n    let sekvenca = flow.get('moja_sekvenca') || [];\n\n    // 5. Dodaj novu čistu točku na kraj liste\n    sekvenca.push(novaTocka);\n\n    // 6. Spremi natrag u zajedničku memoriju\n    flow.set('moja_sekvenca', sekvenca);\n\n    // 7. NA EKRAN ŠALJEMO SAMO KRATKI TEKST (brojevi ostaju skriveni u memoriji)\n    let brojTocke = sekvenca.length;\n    msg.payload = \"Točka \" + brojTocke + \" uspješno zapisana!\";\n    return msg;\n}\n\n// Ako je linija bila tekstualno smeće, ne šalji ništa dalje\nreturn null;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
